# =============================================================================
# Restaurant MERN App - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the server.
# Command: cp .env.example .env
# =============================================================================

# ---- Server Configuration ----
PORT=5000
NODE_ENV=development

# ---- Frontend URL (for CORS) ----
# Set this to your deployed frontend URL in production
FRONTEND_URL=http://localhost:5173

# ---- MongoDB Connection ----
# Local: mongodb://localhost:27017/restaurant-mern
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb://localhost:27017/restaurant-mern

# ---- JWT Authentication ----
# Secret key used to sign and verify JSON Web Tokens
# Use a strong, random string in production (e.g., 64+ character hex string)
JWT_SECRET=your_jwt_secret_key_here

# ---- Admin Credentials ----
# Environment-based admin login (not stored in database)
# The admin login endpoint compares against these values
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=__________

# ---- Cloudinary Configuration ----
# Used for uploading category and menu item images
# Get these values from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
